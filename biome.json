{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "src/**",
      "catalog/shaders/**",
      "catalog/images/**",
      "catalog/composites/**",
      "test/**",
      "scripts/**",
      "demo/app/**",
      "demo/src/**",
      "app.plugin.js",
      "plugin/src/**",
      "plugin/build/**",
      "web-driver/**",
      "*.ts",
      "*.json",
      "!web-driver/shaders.generated.ts"
    ]
  },
  "overrides": [
    {
      "includes": ["plugin/build/**"],
      "linter": { "enabled": false },
      "assist": { "enabled": false }
    }
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
