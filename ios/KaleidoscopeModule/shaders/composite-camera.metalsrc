#include <metal_stdlib>
#include <simd/simd.h>

using namespace metal;

struct main0_out
{
    float4 oColor [[color(0)]];
};

struct main0_in
{
    float2 vUv [[user(locn0)]];
};

fragment main0_out main0(main0_in in [[stage_in]], texture2d<float> uCamera [[texture(0)]], sampler uCameraSmplr [[sampler(0)]])
{
    main0_out out = {};
    out.oColor = float4(uCamera.sample(uCameraSmplr, in.vUv).xyz, 1.0);
    return out;
}

