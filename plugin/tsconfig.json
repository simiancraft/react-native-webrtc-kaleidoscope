{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "lib": ["ES2020"],
    "jsx": "preserve",
    "outDir": "./build",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["build", "node_modules"]
}
