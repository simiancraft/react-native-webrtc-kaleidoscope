  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && tsgo -p tsconfig.build.json && bun run copy:assets",
    "typecheck": "tsgo --noEmit",
    "typecheck:test": "tsgo --noEmit --project tsconfig.test.json",
    "typecheck:demo": "cd demo && bunx tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write .",
    "test": "bun test",
    "check": "bun run lint:fix && bun run typecheck && bun run typecheck:test && bun run typecheck:demo && bun run build && (cd demo && bun run build) && bun run test && bun run check:knip && bun run check:package",
    "check:package": "publint --strict",
    "check:knip": "knip",
    "refresh:android": "cd demo && npm install",
    "prebuild:android": "bun run refresh:android && cd demo && bunx expo prebuild --platform android --no-install",
    "check:android": "cd demo/android && ./gradlew :react-native-webrtc-kaleidoscope:compileDebugKotlin",
    "build:shaders": "bun run scripts/build-shaders.ts",
    "check:shaders": "bun run build:shaders && git diff --exit-code -- android/src/main/java/com/simiancraft/kaleidoscope/gpu/ShadersGenerated.kt src/web/shaders.generated.ts",
    "demo": "bun run build && cd demo && bun run start",
    "demo:wsl": "bun run build && cd demo && bun run start:wsl",
