  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && tsgo -p tsconfig.build.json && bun run copy:assets",
    "typecheck": "tsgo --noEmit",
    "typecheck:test": "tsgo --noEmit --project tsconfig.test.json",
    "typecheck:demo": "cd demo && bunx tsc --noEmit",
    "prepare": "command -v lefthook >/dev/null 2>&1 && lefthook install || true",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write .",
    "test": "bun test",
    "check": "bun run lint:fix && bun run typecheck && bun run typecheck:test && bun run typecheck:demo && bun run check:react-compiler && bun run check:plugin && bun run build && (cd demo && bun run build) && bun run test && bun run check:knip && bun run check:package && bun run check:kotlin && bun run check:swift",
    "check:package": "publint --strict",
    "check:knip": "knip",
    "check:react-compiler": "eslint src/components 'catalog/composites/**/*.controls.tsx' 'catalog/shaders/**/*.form.tsx'",
    "check:kotlin": "bun run scripts/ktlint.ts",
    "format:kotlin": "bun run scripts/ktlint.ts --format",
    "check:swift": "bun run scripts/swift.ts",
    "format:swift": "bun run scripts/swift.ts --format",
    "build:plugin": "bun run scripts/build-plugin.ts",
    "check:plugin": "bun run build:plugin && git diff --exit-code -- plugin/build",
    "refresh:android": "cd demo && npm install",
    "prebuild:android": "bun run refresh:android && cd demo && bunx expo prebuild --platform android --no-install",
    "check:android": "cd demo/android && ./gradlew :react-native-webrtc-kaleidoscope:compileDebugKotlin",
    "build:shaders": "bun run scripts/build-shaders.ts",
    "check:shaders": "bun run build:shaders && git diff --exit-code -- android/src/main/java/com/simiancraft/kaleidoscope/gpu/ShadersGenerated.kt web-driver/shaders.generated.ts",
    "bench:shader": "bun run scripts/shader-cost.ts",
    "shader:view": "bun run scripts/shader-view.ts",
    "thumbs": "bun run build && bun tools/thumbnails/make-thumbnails.ts --book demo/kaleidoscope.preset-book.ts --out demo/assets/thumbnails --repo",
    "gen:waffle": "bun run scripts/gen-preset-waffle.ts",
    "check:waffle": "bun run scripts/gen-preset-waffle.ts --check",
    "demo": "bun run build && cd demo && bun run start",
    "demo:wsl": "bun run build && cd demo && bun run start:wsl",
    "demo:ios": "bun run build && cd demo && bun run ios",
    "demo:android": "bun run build && cd demo && bun run android",
    "demo:web": "bun run build && cd demo && bun run web",
    "build:web": "bun run build && cd demo && bunx expo export -p web",
    "prepack": "bun run build:plugin && bun run build",
    "prepublishOnly": "bun run build:plugin && bun run build && bun run check:package",
    "copy:assets": "bun run scripts/copy-assets.ts",
    "verify:web": "(cd demo && bunx expo export -p web) && bun run scripts/verify-web-presets.ts"
  },
